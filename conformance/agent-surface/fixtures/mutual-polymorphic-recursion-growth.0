fun left<T>(value: T) -> Void {
    let nested: Maybe<T> = null
    right<Maybe<T>>(nested)
}

fun right<T>(value: T) -> Void {
    let nested: Maybe<T> = null
    left<Maybe<T>>(nested)
}

pub fun main(world: World) -> Void raises {
    left<i32>(1)
    check world.out.write("mutual polymorphic recursion ok\n")
}

fun gcd(a: u32, b: u32) -> u32 {
    let mut left = a
    let mut right = b
    while right != 0 {
        let next = left % right
        left = right
        right = next
    }
    return left
}

pub fun main(world: World) -> Void raises {
    if gcd(84, 30) == 6 {
        check world.out.write("gcd ok\n")
    }
}

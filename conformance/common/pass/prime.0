fun isPrime(n: u32) -> Bool {
    if n < 2 {
        return false
    }
    let mut divisor: u32 = 2
    while divisor * divisor <= n {
        if n % divisor == 0 {
            return false
        }
        divisor = divisor + 1
    }
    return true
}

pub fun main(world: World) -> Void raises {
    if isPrime(2) && isPrime(29) && isPrime(30) == false {
        check world.out.write("prime ok\n")
    }
}

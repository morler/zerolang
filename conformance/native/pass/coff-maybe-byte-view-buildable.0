export c fn main u8
  mut storage [8]u8 [0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8]
  mut alloc FixedBufAlloc std.mem.fixedBufAlloc storage
  let first std.mem.allocBytes alloc 4
  if first.has
    if == (std.mem.len first.value) 4
      let bytes MutSpan<u8> first.value
      if == (std.mem.len bytes) 4
        ret first.value[0]
  ret 0_u8

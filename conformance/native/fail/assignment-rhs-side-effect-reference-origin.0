shape Holder {
    value: ref<i32>,
    count: i32,
}

fun replaceValue(holder: mutref<Holder>, next: ref<i32>) -> i32 {
    holder.value = next
    return 1
}

pub fun main() -> Void {
    let old = 1
    let mut next = 2
    let mut holder = Holder { value: &old, count: 0 }
    holder.count = replaceValue(&mut holder, &next)
    next = 3
}
